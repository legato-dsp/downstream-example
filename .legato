// A single FM mod + carrier with ADSR on both oscillators
patch fm() {
    in freq_mod freq_carrier gain

    audio {
        sine: mod { },
        sine: carrier { },
        add: fm_add { val: 0.0 }, // This is confusing, find better semantics.
        mult: fm_gain { val: 1.0 } // Default
    }

    freq_mod >> mod

    freq_carrier >> fm_add[0]

    gain >> fm_gain.val

    mod >> fm_gain[0]
    
    fm_gain >> fm_add[1]

    fm_add >> carrier

    { carrier }
}

audio {
    fm { }
}

control {
    signal: f_mod { name: "f_mod", min: 24.0, max: 24000.0, default: 550.0 },
    signal: f_carrier { name: "f_carrier", min: 24.0, max: 24000.0, default: 440.0 },
    signal: f_gain { name: "f_gain", min: 0.0, max: 10000.0, default: 1000.0 }
}

f_mod >> fm.freq_mod
f_carrier >> fm.freq_carrier
f_gain >> fm.gain

{ fm }